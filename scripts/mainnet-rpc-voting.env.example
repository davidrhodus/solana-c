# /etc/solana-c/mainnet-rpc-voting.env
#
# Required:
# - IDENTITY_PATH: validator identity keypair JSON path
# - VOTE_ACCOUNT: vote account keypair JSON path, or base58 vote pubkey
#
# Optional:
# - Override any defaults from scripts/run-mainnet-rpc-voting.sh

LEDGER_DIR=ledger.mainnet
IDENTITY_PATH=/var/solana/identity.json
VOTE_ACCOUNT=/var/solana/vote-account.json

# Networking
RPC_BIND=127.0.0.1
RPC_PORT=8899
GOSSIP_PORT=8001
TPU_PORT=8003
TVU_PORT=8004

# Paths
ROCKSDB_PATH=ledger.mainnet/rocksdb
LOG_FILE=ledger.mainnet/validator.log

# RPC backpressure (replay-protective defaults)
SOL_SKIP_TX_INDEX=1
SOL_RPC_BACKPRESSURE=1
SOL_RPC_BACKPRESSURE_ADAPTIVE_GROWTH=1
SOL_RPC_BACKPRESSURE_HIGH_SLOTS=192
SOL_RPC_BACKPRESSURE_SEVERE_SLOTS=768
SOL_RPC_BACKPRESSURE_CLEAR_SLOTS=96
SOL_RPC_BACKPRESSURE_HIGH_GROWTH_SLOTS=24
SOL_RPC_BACKPRESSURE_SEVERE_GROWTH_SLOTS=72
SOL_RPC_BACKPRESSURE_HIGH_RPS=350
SOL_RPC_BACKPRESSURE_SEVERE_RPS=120
SOL_RPC_BACKPRESSURE_HIGH_MAX_CONN=96
SOL_RPC_BACKPRESSURE_SEVERE_MAX_CONN=48
SOL_RPC_BACKPRESSURE_REJECT_MODE=2

# TVU replay scheduler (lag-aware parent probing)
SOL_TVU_REPLAY_PARENT_PROBE_LIMIT=48
SOL_TVU_REPLAY_PARENT_PROBE_HIGH_LAG=192
SOL_TVU_REPLAY_PARENT_PROBE_SEVERE_LAG=768
